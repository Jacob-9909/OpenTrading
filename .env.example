APP_ENV=local
DATABASE_URL=sqlite:///./coin_trading.db
TRADING_MODE=paper
PORTFOLIO_SOURCE=paper
LIVE_TRADING_ENABLED=false
LIVE_ORDER_TYPE=limit
LIVE_MIN_ORDER_KRW=5000
LIVE_MAX_ORDER_KRW=100000
EXCHANGE=bithumb_spot
SYMBOL=KRW-BTC
TIMEFRAME=1h
LOOKBACK_LIMIT=200
ANALYSIS_TIMEFRAMES=1h,4h,1d
RECENT_CANDLE_LIMIT=60
DASHBOARD_CHART_TIMEFRAME=10m
DASHBOARD_CHART_DAYS=10

INITIAL_EQUITY=10000
RISK_PER_TRADE=0.01
DAILY_MAX_LOSS=0.03
MAX_LEVERAGE=1
MAX_OPEN_POSITIONS=1
MAX_POSITION_ALLOCATION_PCT=30
LIQUIDATION_BUFFER=0.08
KILL_SWITCH_DRAWDOWN=0.10

LLM_PROVIDER=openrouter
LLM_MODEL=google/gemma-4-31b-it:free
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

BINANCE_API_KEY=
BINANCE_API_SECRET=
BITHUMB_ACCESS_KEY=
BITHUMB_SECRET_KEY=

NEWS_RSS_URLS=https://www.coindesk.com/arc/outboundfeeds/rss/,https://cointelegraph.com/rss
SCHEDULER_INTERVAL_MINUTES=60
RUN_ONCE_INTERVAL_MINUTES=360
DATA_REFRESH_INTERVAL_MINUTES=240
SCHEDULER_TIMEZONE=Asia/Seoul
DECISION_TIMES=09:00
DECISION_INTERVAL_MINUTES=60
DECISION_COOLDOWN_MINUTES=1440
MAX_DATA_STALENESS_MINUTES=180
