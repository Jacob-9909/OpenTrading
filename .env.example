APP_ENV=local
DATABASE_URL=sqlite:///./coin_trading.db

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │                         트레이딩 모드 선택                                   │
# │                                                                             │
# │  아래 3개 블록 중 하나를 선택해 주석을 해제하고, 나머지 2개는 주석 처리하세요.  │
# │                                                                             │
# │  ①  실제 코인  — Bithumb 실계좌, 실제 주문                                   │
# │  ②  모의 코인  — Bithumb 시세, 가상 주문 (기본값)                             │
# │  ③  모의 주식  — Yahoo Finance 시세, 가상 주문                                │
# └─────────────────────────────────────────────────────────────────────────────┘


# ══════════════════════════════════════════════════════════════════════════════
# ①  실제 코인 (주석 해제 시 활성화)
# ══════════════════════════════════════════════════════════════════════════════
# TRADING_MODE=live
# PORTFOLIO_SOURCE=exchange
# EXCHANGE=bithumb_spot
# LIVE_TRADING_ENABLED=true
# SYMBOL=KRW-BTC
# INITIAL_EQUITY=<실제 시작 잔고 KRW>   # 수익률 계산 기준점
#
# LIVE_ORDER_TYPE=limit              # limit | market
# LIVE_MIN_ORDER_KRW=5000            # 주문 최소 금액
# LIVE_MAX_ORDER_KRW=100000          # 주문 최대 금액 (안전 상한)
#
# BITHUMB_ACCESS_KEY=<발급받은 키>
# BITHUMB_SECRET_KEY=<발급받은 키>
#
# SCHEDULER_TIMEZONE=Asia/Seoul
# NEWS_RSS_URLS=https://www.coindesk.com/arc/outboundfeeds/rss/,https://cointelegraph.com/rss


# ══════════════════════════════════════════════════════════════════════════════
# ②  모의 코인 — 기본값 (주석 해제 시 활성화)
# ══════════════════════════════════════════════════════════════════════════════
TRADING_MODE=paper
PORTFOLIO_SOURCE=paper
EXCHANGE=bithumb_spot
LIVE_TRADING_ENABLED=false
SYMBOL=KRW-BTC
INITIAL_EQUITY=10000000              # 가상 초기 자금 (KRW)

LIVE_ORDER_TYPE=limit
LIVE_MIN_ORDER_KRW=5000
LIVE_MAX_ORDER_KRW=100000

BITHUMB_ACCESS_KEY=
BITHUMB_SECRET_KEY=

SCHEDULER_TIMEZONE=Asia/Seoul

# 뉴스 수집 (coindesk = CoinDesk Data API, rss = RSS 피드)
NEWS_SOURCE=coindesk
COINDESK_API_KEY=
COINDESK_LANG=EN
# COINDESK_CATEGORIES=BTC,ETH                # 빈 값이면 전체
# COINDESK_EXCLUDE_CATEGORIES=
COINDESK_FETCH_LIMIT=50
# RSS fallback (NEWS_SOURCE=rss 일 때만 사용)
# NEWS_RSS_URLS=https://www.coindesk.com/arc/outboundfeeds/rss/,https://cointelegraph.com/rss


# ══════════════════════════════════════════════════════════════════════════════
# ③  모의 주식 (주석 해제 시 활성화)
# ══════════════════════════════════════════════════════════════════════════════
# TRADING_MODE=paper
# PORTFOLIO_SOURCE=paper
# EXCHANGE=yfinance
# LIVE_TRADING_ENABLED=false
# SYMBOL=AAPL                        # US 주식 예시
# # SYMBOL=005930.KS                 # 삼성전자 예시
# INITIAL_EQUITY=10000               # 가상 초기 자금 (USD)
#
# LIVE_ORDER_TYPE=limit
# LIVE_MIN_ORDER_KRW=5000
# LIVE_MAX_ORDER_KRW=100000
#
# BITHUMB_ACCESS_KEY=
# BITHUMB_SECRET_KEY=
#
# SCHEDULER_TIMEZONE=America/New_York         # US 시장 기준
# # SCHEDULER_TIMEZONE=Asia/Seoul             # 한국 주식 시장 기준
# NEWS_RSS_URLS=https://feeds.content.dowjones.io/public/rss/mw_topstories,https://finance.yahoo.com/news/rssindex


# ══════════════════════════════════════════════════════════════════════════════
# 공통 설정 (모든 모드에서 사용)
# ══════════════════════════════════════════════════════════════════════════════

# ── 시장 데이터 ───────────────────────────────────────────────────────────────
TIMEFRAME=10m
LOOKBACK_LIMIT=500
ANALYSIS_TIMEFRAMES=10m,30m,1h,4h,1d
RECENT_CANDLE_LIMIT=60
DASHBOARD_CHART_TIMEFRAME=10m
DASHBOARD_CHART_DAYS=7

# ── 리스크 관리 ───────────────────────────────────────────────────────────────
RISK_PER_TRADE=0.05                  # 거래당 리스크 (자산 대비 비율)
MAX_LEVERAGE=1                       # 최대 레버리지 (코인: 1~3, 주식: 1 고정)
MAX_POSITION_ALLOCATION_PCT=20       # 단일 포지션 최대 자산 비율 (%)
LIQUIDATION_BUFFER=0.08
KILL_SWITCH_DRAWDOWN=0.10

# ── 동적 SL/TP ────────────────────────────────────────────────────────────────
# 가격이 TP를 돌파하면 → TP를 0.5% 더 연장 + comeback trigger 대기
TRAILING_TP_PCT=0.005
# 수익 방향으로 SL이 0.3% 간격으로 따라감
TRAILING_STOP_PCT=0.003

# 참고: LLM이 설정하는 SL/TP는 코드 레벨에서 자동 보정됨
#   - SL 거리 ≥ max(1.5 × ATR, entry × 0.3%)
#   - TP 거리 ≥ max(3.0 × ATR, entry × 0.6%)
#   - Risk/Reward ≥ 2:1
#   - LONG  RSI 30–65 / SHORT RSI 35–70

# ── LLM 제공자 ────────────────────────────────────────────────────────────────
# 펀드매니저 (최종 결정)
LLM_PROVIDER=openrouter              # mock | openai | gemini | openrouter | nvidia
LLM_MODEL=google/gemma-4-31b-it:free

# 애널리스트 (기술적 + 심리 분석) — 미설정 시 LLM_PROVIDER/LLM_MODEL 사용
ANALYST_LLM_PROVIDER=
ANALYST_LLM_MODEL=

# 리서처 (불/베어 논쟁) — 미설정 시 LLM_PROVIDER/LLM_MODEL 사용
RESEARCHER_LLM_PROVIDER=
RESEARCHER_LLM_MODEL=

OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# ── 스케줄러 ──────────────────────────────────────────────────────────────────
RUN_ONCE_INTERVAL_MINUTES=15         # serve-all 파이프라인 실행 주기 (분)
DECISION_COOLDOWN_MINUTES=0          # 동일 종목 재결정 최소 간격 (0=제한없음)
MAX_DATA_STALENESS_MINUTES=5760      # 데이터 신선도 한계 (분)

# ── 가격 일관성 체크 (serve-all 전용) ────────────────────────────────────────
# LLM 결정 중 가격이 이 비율 이상 움직이면 주문 취소
PRICE_CONSISTENCY_THRESHOLD_PCT=0.5

# ══════════════════════════════════════════════════════════════════════════════
# 알림 (Slack)
# ══════════════════════════════════════════════════════════════════════════════
# 신규 LONG/SHORT 진입, SL/TP 체결, 헬스체크(08/15/21시) 알림
SLACK_WEBHOOK_URL=

# ══════════════════════════════════════════════════════════════════════════════
# Vertex AI / Gemini (신규 진입 시 메시지 요약용 — 선택사항)
# ══════════════════════════════════════════════════════════════════════════════
VERTEX_PROJECT_ID=
VERTEX_MODEL_ID=gemini-2.5-flash
VERTEX_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
